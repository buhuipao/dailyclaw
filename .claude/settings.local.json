{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "Bash(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)"
    ],
    "deny": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo *)",
      "Bash(chmod -R 777 *)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(shutdown*)",
      "Bash(reboot*)"
    ]
  }
}
